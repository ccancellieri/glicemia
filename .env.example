# GliceMia — Environment Configuration
# Copy this file to .env and fill in your values

# === AI Backend (LiteLLM) ===
# Default: Gemini 2.5 Flash (free, no credit card needed)
# Get key at: https://ai.google.dev
AI_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Ollama (local, free, no API key)
# AI_MODEL=ollama/llama3
# OLLAMA_API_BASE=http://localhost:11434

# Optional: Claude API
# AI_MODEL=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Telegram Bot ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Authorized Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=

# === CareLink ===
# Country code (e.g., it, es, de, fr, gb)
CARELINK_COUNTRY=it
# CareLink username
CARELINK_USERNAME=your_carelink_username
# CareLink password
CARELINK_PASSWORD=your_carelink_password
# Polling interval in seconds (default: 300 = 5 minutes)
CARELINK_POLL_INTERVAL=300

# === Database ===
# SQLCipher encryption passphrase (CHANGE THIS!)
DB_PASSPHRASE=change_this_to_a_strong_passphrase
# Database file path
DB_PATH=glicemia.db

# === TTS (Text-to-Speech for voice replies) ===
# edge-tts is used by default (free, no API key needed)
# Optional: LiteLLM TTS fallback (e.g., openai/tts-1 — costs money)
# TTS_MODEL=openai/tts-1

# === External APIs (free tiers) ===
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# OpenRouteService: https://openrouteservice.org/dev/
ORS_API_KEY=your_openrouteservice_key_here

# === WebApp (Telegram Mini App) ===
# Port for the local API server
WEBAPP_PORT=8443

# Public HTTPS URL for the Mini App (required for Telegram)
# Option A: GitHub Pages (free, no server needed for frontend):
#   1. Push to GitHub, enable Pages on /docs
#   2. WEBAPP_URL=https://youruser.github.io/diabete/webapp/?api=https://xxxx.ngrok-free.app
#      (the ?api= parameter tells the frontend where the API is)
#
# Option B: ngrok tunnel (serves both frontend + API from your machine):
#   ngrok http 8443
#   WEBAPP_URL=https://xxxx.ngrok-free.app/webapp
#
# Option C: Cloudflare tunnel (free, stable URL):
#   cloudflared tunnel --url http://localhost:8443
#   WEBAPP_URL=https://xxxx.trycloudflare.com/webapp
WEBAPP_URL=

# === Language ===
# Supported: it, en, es, fr
LANGUAGE=it

# === Patient ===
PATIENT_NAME=YourName
