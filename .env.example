# GliceMia — Environment Configuration (server-wide settings)
# Copy this file to .env and fill in your values.
#
# Per-patient settings (CareLink credentials, name, language, API keys)
# are stored in the encrypted SQLCipher database.
# Use the bot's /adduser command to register each patient.

# === AI Backend (LiteLLM) — server-wide defaults ===
# Default: Gemini 2.5 Flash (free, no credit card needed)
# Get key at: https://ai.google.dev
AI_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Ollama (local, free, no API key)
# AI_MODEL=ollama/qwen2.5:14b-instruct-q4_K_M
# OLLAMA_API_BASE=http://localhost:11434

# Optional: Claude API
# AI_MODEL=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === AI Fallback (optional) ===
# When enabled, if the primary AI_MODEL times out or fails,
# automatically retries with AI_FALLBACK_MODEL.
AI_FALLBACK_ENABLED=false
AI_FALLBACK_MODEL=gemini/gemini-2.5-flash
AI_TIMEOUT_SECONDS=60

# === Telegram Bot ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Bootstrap admin Telegram user IDs (comma-separated).
# These users are auto-registered as admins on first startup.
# After that, admins can add more users via /adduser in the bot.
TELEGRAM_ALLOWED_USERS=

# === Database ===
# SQLCipher encryption passphrase (CHANGE THIS!)
DB_PASSPHRASE=change_this_to_a_strong_passphrase
# Database file path
DB_PATH=glicemia.db

# === TTS (Text-to-Speech for voice replies) ===
# edge-tts is used by default (free, no API key needed)
# TTS_MODEL=openai/tts-1

# === External APIs (server-wide, per-user overrides in DB) ===
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here
# OpenRouteService: https://openrouteservice.org/dev/
ORS_API_KEY=your_openrouteservice_key_here

# === WebApp (Telegram Mini App) ===
WEBAPP_PORT=8443
WEBAPP_URL=
